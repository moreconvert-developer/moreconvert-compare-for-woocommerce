{
  "name": "moreconvert/moreconvert-compare-for-woocommerce",
  "type": "wordpress-plugin",
  "description": "A powerful WooCommerce product comparison plugin...",
  "keywords": ["compare", "woocommerce", "products", "e-commerce", "moreconvert"],
  "homepage": "https://moreconvert.com/product/moreconvert-compare-for-woocommerce/",
  "license": "GPL-3.0",
  "require": {
    "enshrined/svg-sanitize": "^0.22.0"
  },
  "require-dev": {
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "wp-coding-standards/wpcs": "^3.1",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpcsstandards/phpcsutils": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.0"
    }
  },
  "scripts": {
    "phpcs": "phpcs",
    "phpcbf": "phpcbf"
  }
}
